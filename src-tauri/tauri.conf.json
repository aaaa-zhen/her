{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Her",
  "version": "1.0.0",
  "identifier": "com.her.companion",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3456"
  },
  "app": {
    "windows": [
      {
        "title": "Her",
        "width": 420,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/her-sidecar"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
